# ─────────────────────────────────────────────────────────
#  Cartesi RVP — Environment Variables
#  Copy to .env and fill in real values before running.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=rvp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rvp

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_USER=rvp
RABBITMQ_PASSWORD=changeme

# ── Sandbox Manager ───────────────────────────────────────
MAX_SANDBOXES=5
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT=4g

# ── GitHub Watcher ────────────────────────────────────────
# Personal access token with repo:read scope
GITHUB_TOKEN=ghp_xxxx
# Repository to watch for new releases
GITHUB_REPO=cartesi/rollups-node
# Polling interval in seconds (default 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# ── AI Agent ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx

# 32-byte base64 key shared between orchestrator (encrypt) and ai-agent (decrypt) for
# per-session Anthropic API keys stored in ai.sessions.
# REQUIRED — must live in THIS root .env (docker-compose interpolates it; values in
# services/*/.env are NOT sufficient and compose will refuse to start without it).
# Generate via:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
AI_SESSION_KEY=

# ── Discord Notifier ──────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy
