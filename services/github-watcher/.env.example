# ── github-watcher service env ────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to version control.

DATABASE_URL=postgresql+asyncpg://rvp:changeme@localhost:5432/rvp
RABBITMQ_URL=amqp://rvp:changeme@localhost:5672/

# GitHub personal access token — needs repo:read scope
GITHUB_TOKEN=ghp_xxxx

# ── Repositories to watch ─────────────────────────────────────────────────────

# rollups-node releases (the primary trigger for validation runs)
GITHUB_REPO=cartesi/rollups-node

# CLI releases — tracked independently so that if a new @cartesi/cli comes out
# that references an already-catalogued node version, the toolchain is backfilled
# and a run is triggered automatically if none has occurred yet.
CLI_GITHUB_REPO=cartesi/cli

# rollups-contracts releases — keeps contracts_catalog fresh
CONTRACTS_GITHUB_REPO=cartesi/rollups-contracts

# ── Polling ───────────────────────────────────────────────────────────────────

# Interval between poll cycles in seconds (default 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# Set to "false" to disable the independent CLI release poller
CLI_POLL_ENABLED=true

# Stop polling if GitHub rate limit drops below this many remaining requests
RATE_LIMIT_FLOOR=20

# ── Webhook secrets ───────────────────────────────────────────────────────────
# Both repos can point to the same /webhook endpoint on port 8001.
# The handler identifies the source from payload["repository"]["full_name"].

# Shared secret configured in cartesi/rollups-node → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_node_webhook_secret

# Shared secret configured in cartesi/cli → Settings → Webhooks
# Leave blank to reuse GITHUB_WEBHOOK_SECRET for both repos
CLI_GITHUB_WEBHOOK_SECRET=your_cli_webhook_secret
