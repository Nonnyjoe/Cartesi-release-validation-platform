# ── github-watcher service env ────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to version control.

DATABASE_URL=postgresql+asyncpg://rvp:changeme@localhost:5432/rvp
RABBITMQ_URL=amqp://rvp:changeme@localhost:5672/

# GitHub personal access token — needs repo:read scope
GITHUB_TOKEN=ghp_xxxx

# Repository to watch for new rollups-node releases (owner/repo)
GITHUB_REPO=cartesi/rollups-node

# Repository where CLI releases are published — used to resolve the
# @cartesi/sdk and @cartesi/cli versions that ship with each node release.
CLI_GITHUB_REPO=cartesi/cli

# Repository tracking rollups-contracts releases
CONTRACTS_GITHUB_REPO=cartesi/rollups-contracts

# Polling interval in seconds (default 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# Optionally override the node version used for the validation run
# NODE_VERSION_OVERRIDE=1.5.0
