# ── sandbox-manager service env ───────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to version control.

DATABASE_URL=postgresql+asyncpg://rvp:changeme@localhost:5432/rvp
RABBITMQ_URL=amqp://rvp:changeme@localhost:5672/

# Concurrency and resource limits for spawned sandbox containers
MAX_SANDBOXES=5
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT=4g
