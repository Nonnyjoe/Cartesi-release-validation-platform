# ── orchestrator service env ──────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to version control.
#
# For local dev (outside Docker): use localhost URLs.
# For Docker Compose: URLs use service names (postgres, rabbitmq, redis).

DATABASE_URL=postgresql+asyncpg://rvp:changeme@localhost:5432/rvp
RABBITMQ_URL=amqp://rvp:changeme@localhost:5672/
REDIS_URL=redis://localhost:6379

# GitHub token for release catalog sync (repo:read scope)
GITHUB_TOKEN=ghp_xxxx

# Repository where CLI releases are published — used by /releases/sync to
# resolve the @cartesi/sdk and @cartesi/cli versions for each node release.
CLI_GITHUB_REPO=cartesi/cli

# Repository where rollups-contracts releases are published — used by
# /releases/contracts/sync to track contract versions.
CONTRACTS_GITHUB_REPO=cartesi/rollups-contracts
